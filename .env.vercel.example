# Vercel production example
# Copy these keys into Vercel Project Settings -> Environment Variables.

# Core app
NODE_ENV=production

# Admin login
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_SESSION_SECRET=replace-with-32-byte-random-string

# Google tag (optional override; admin SEO setting has priority)
# NEXT_PUBLIC_GOOGLE_TAG_ID=GT-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Image delivery
NEXT_PUBLIC_R2_URL=https://pub-xxxxxxxxxxxxxx.r2.dev
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Leave NEXT_IMAGE_UNOPTIMIZED unset on Vercel.

# Optional notifications
WECOM_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
SERVERCHAN_SENDKEY=
NEXT_PUBLIC_WEB3FORMS_KEY=
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional AI features
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_ARTICLE_MODEL=
AI_ARTICLE_REASONING_EFFORT=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Required on Vercel if you want admin writes to persist.
# Without these, the app falls back to local data/*.json storage, which is not suitable for Vercel runtime.
KV_REST_API_URL=
KV_REST_API_TOKEN=
