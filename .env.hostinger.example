# Required auth settings
AUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=https://your-domain.com

# Admin login (environment-variable based, no database needed).
# ADMIN_USERNAME / ADMIN_PASSWORD are all you need to log into /admin.
# To change the password later: edit ADMIN_PASSWORD here and redeploy.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-your-password
# Optional: if set, a bcrypt hash takes priority over the plain ADMIN_PASSWORD.
# ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# Required database settings
# Hostinger MySQL example:
# mysql://DB_USER:DB_PASSWORD@HOST:3306/DB_NAME
DATABASE_URL=mysql://u837198489_user:replace-with-password@srv2228.hstgr.io:3306/u837198489_b5xhC

# Required for AI article generation
OPENAI_API_KEY=replace-with-your-api-key

# Optional AI relay / model settings
OPENAI_BASE_URL=https://dm-fox.rjj.cc/codex/v1
AI_ARTICLE_MODEL=gpt-5.5
AI_ARTICLE_REASONING_EFFORT=high

# Optional image upload settings
# Hostinger File Manager / local storage mode
ALLOW_LOCAL_FILE_UPLOADS=true

# Optional object storage
BLOB_READ_WRITE_TOKEN=

# Optional Claude / Anthropic settings for image alt generation
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
