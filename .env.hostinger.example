# Hostinger shared Node.js example
# Copy these keys into hPanel and replace placeholder values.

# Core app
NODE_ENV=production
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@HOST:3306/DB_NAME

# Admin login
ADMIN_PASSWORD=replace-with-strong-admin-password

# Google tag (optional override; admin SEO setting has priority)
# NEXT_PUBLIC_GOOGLE_TAG_ID=GT-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Image delivery
NEXT_PUBLIC_R2_URL=https://pub-xxxxxxxxxxxxxx.r2.dev
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
ALLOW_LOCAL_FILE_UPLOADS=true
NEXT_IMAGE_UNOPTIMIZED=true

# Optional notifications
WECOM_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
SERVERCHAN_SENDKEY=
NEXT_PUBLIC_WEB3FORMS_KEY=
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional AI features
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_ARTICLE_MODEL=
AI_ARTICLE_REASONING_EFFORT=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
