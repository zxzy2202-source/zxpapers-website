# Required auth settings
AUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=https://your-domain.com

# Required database settings
# Recommended for Hostinger Node.js Hosting: use Turso/libSQL instead of local SQLite.
DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=replace-with-your-turso-token

# Required for AI article generation
OPENAI_API_KEY=replace-with-your-api-key

# Optional AI relay / model settings
OPENAI_BASE_URL=https://dm-fox.rjj.cc/codex/v1
AI_ARTICLE_MODEL=gpt-5.5
AI_ARTICLE_REASONING_EFFORT=high

# Optional image upload settings
# Strongly recommended for production if you want uploads to persist after redeploys.
BLOB_READ_WRITE_TOKEN=
# Keep this false on Hostinger production unless you intentionally accept local-file uploads.
ALLOW_LOCAL_FILE_UPLOADS=false

# Optional Claude / Anthropic settings for image alt generation
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
