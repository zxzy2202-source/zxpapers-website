generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// 管理员账号
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 询盘
model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  country   String?
  phone     String?
  product   String?
  message   String
  status    String   @default("NEW")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 文章
model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  category    String    @default("INDUSTRY_INSIGHTS")
  status      String    @default("DRAFT")
  coverImage  String?
  tags        String?   @default("")
  metaTitle   String?
  metaDesc    String?
  keywords    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 图片资源
model ImageAsset {
  id            String            @id @default(cuid())
  filename      String
  originalName  String?
  path          String
  alt           String?
  page          String?
  label         String?
  tags          String?
  mimeType      String?
  storageType   String            @default("local")
  source        String            @default("admin")
  width         Int?
  height        Int?
  size          Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  slotBindings  ImageSlotRecord[]
}

// 图片槽位记录（Page / Section / Slot）
model ImageSlotRecord {
  id            String      @id @default(cuid())
  slotKey       String      @unique
  pageKey       String
  pageName      String
  pagePath      String
  sectionKey    String
  sectionName   String
  slotName      String
  label         String
  description   String?
  aspectRatio   String      @default("16:9")
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)
  imageAssetId  String?
  imageAsset    ImageAsset? @relation(fields: [imageAssetId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([pageKey, sortOrder])
  @@index([imageAssetId])
}
