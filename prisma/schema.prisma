generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// 管理员账号
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 询盘
model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  country   String?
  phone     String?
  product   String?
  message   String
  status    String   @default("NEW")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 文章
model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  category    String    @default("INDUSTRY_INSIGHTS")
  status      String    @default("DRAFT")
  coverImage  String?
  metaTitle   String?
  metaDesc    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 图片资源
model ImageAsset {
  id        String   @id @default(cuid())
  filename  String
  path      String
  alt       String?
  page      String?
  width     Int?
  height    Int?
  size      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
