# Copy to .env.local and replace with real values.

# --- Cloudflare R2 image storage ---
NEXT_PUBLIC_R2_URL=https://pub-xxxxxxxxxxxxxx.r2.dev
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Shared-host only. Set to true on platforms like Hostinger if first-hit /_next/image is too slow.
# NEXT_IMAGE_UNOPTIMIZED=true

# --- Admin login ---
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_SESSION_SECRET=replace-with-32-byte-random-string

# --- Google tag (optional override; admin SEO setting has priority) ---
# NEXT_PUBLIC_GOOGLE_TAG_ID=GT-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# --- Inquiry notification channels ---
WECOM_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
SERVERCHAN_SENDKEY=
NEXT_PUBLIC_WEB3FORMS_KEY=
GOOGLE_SHEETS_WEBHOOK_URL=

# --- Vercel KV (auto-injected after Vercel deploy) ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Scheduled Blog publishing ---
# Use a random value of at least 16 characters. Vercel sends it as a Bearer token.
CRON_SECRET=replace-with-random-16-plus-character-secret

# --- Feishu Base Blog image matching ---
# Use the bot/app identity in production. Grant the app access to the target Base and table.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ASSET_BASE_TOKEN=
FEISHU_ASSET_TABLE_ID=
FEISHU_ASSET_ATTACHMENT_FIELD_ID=
# Optional for Lark international tenants. Feishu defaults to https://open.feishu.cn.
# FEISHU_OPEN_API_BASE=https://open.feishu.cn
